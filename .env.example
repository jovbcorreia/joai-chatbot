# ─────────────────────────────────────────────
#  JoAI Chatbot — Environment Variables
#  Copy this file to .env and fill in values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# AI Provider: 'openrouter' (cloud) or 'ollama' (local)
AI_PROVIDER=openrouter

# OpenRouter API Key — get yours free at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model to use (see https://openrouter.ai/models for full list)
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Ollama local endpoint (only needed if AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3

# Set to 'true' to fall back to Ollama when OpenRouter fails
OLLAMA_FALLBACK=false

# Backend server port
PORT=3001

# Frontend URL — used for CORS whitelist
CLIENT_URL=http://localhost:5173
